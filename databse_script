-- Product Catalog Database Script (MySQL version)
-- NOTE: This script targets MySQL instead of MS SQL Server as specified 
-- in the assignment. Syntax adapted accordingly (AUTO_INCREMENT, VARCHAR, 
-- CURRENT_TIMESTAMP). Please advise if a SQL Server version is required.
-- ============================================================

CREATE DATABASE IF NOT EXISTS ProductCatalogDb;
USE ProductCatalogDb;

DROP TABLE IF EXISTS Products;

CREATE TABLE Products
(
    Id              INT AUTO_INCREMENT PRIMARY KEY,
    Name            VARCHAR(200)   NOT NULL,
    Description     VARCHAR(1000)  NULL,
    Price           DECIMAL(10,2)  NOT NULL,
    Category        VARCHAR(100)   NOT NULL,
    ImageUrl        VARCHAR(500)   NULL,
    StockQuantity   INT            NOT NULL DEFAULT 0,
    CreatedDate     DATETIME       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    LastUpdatedDate DATETIME       NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX IX_Products_Category ON Products (Category);
CREATE INDEX IX_Products_Price ON Products (Price);

